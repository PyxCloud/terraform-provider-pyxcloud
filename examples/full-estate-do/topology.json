    { "name": "app-images",   "type": "container-registry", "tier": "professional", "garbage_collection": true, "note": "AWS ECR -> DO Container Registry" },
    { "name": "jit-allowlist","type": "key-value-store", "memory_gb": 1, "ha": true, "note": "DynamoDB -> DO Managed Redis (private)" },
