    { "name": "app-monitoring", "type": "monitoring", "cluster": "backend", "scrape_targets": ["backend"], "alarms": ["backend-cpu-high", "backend-5xx"], "tempo_datasource": "app-traces", "note": "CloudWatch + SNS -> LGTM (kube-prometheus-stack + Loki + Grafana + Alertmanager) on DOKS via the operator pattern; CloudWatch alarms -> PrometheusRule alerts -> Alertmanager" },
    { "name": "app-tls",      "type": "tls-certificate", "domains": ["app.passo.build", "admin.passo.build"], "production": true, "cluster": "backend", "note": "ACM -> cert-manager + Let's Encrypt on DOKS" },
    { "name": "nightly",      "type": "scheduled-trigger", "schedule": "cron(0 3 * * ? *)", "cluster": "backend", "note": "EventBridge cron -> DOKS CronJob" },
    { "name": "vpn-endpoint", "type": "reserved-ip", "note": "Elastic IP -> DO Reserved IP (VPN stable endpoint)" },
    { "name": "app-secrets",  "type": "secrets-manager", "rotation_days": 30, "note": "Secrets Manager -> self-hosted Vault on DO (mitigation)" }
  ]
