{
  "name": "production",
  "region": "Gravelines",
  "cidr": "10.0.0.0/16",
  "subnets": ["10.0.1.0/24", "10.0.2.0/24"],
  "managed_database": {
    "name": "app-db",
    "engine": "postgres",
    "cpu": 2,
    "ram": 7,
    "storage_gb": 40,
    "ha": true,
    "deletion_protection": false
