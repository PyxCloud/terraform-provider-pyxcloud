{
  "name": "production",
  "region": "Frankfurt",
  "cidr": "10.0.0.0/16",
  "subnets": ["10.0.1.0/24", "10.0.2.0/24"],
  "security_group": {
    "name": "production-db",
    "description": "PyxCloud data tier - Postgres reachable from the app subnet only",
    "rules": [
      { "direction": "ingress", "protocol": "tcp", "from_port": 5432, "to_port": 5432, "cidrs": ["10.0.0.0/16"] }
    ]
  },
  "managed_database": {
    "name": "app-db",
    "engine": "postgres",
    "version": "16",
    "cpu": 2,
    "ram": 4,
    "storage_gb": 50,
    "ha": true,
    "encrypted": true,
    "security_group": "production-db"
  }
}
